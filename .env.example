# Convex deployment URL (set by init_app_project tool or npx convex dev)
VITE_CONVEX_URL=

# For local development with npx convex dev
# CONVEX_DEPLOY_KEY=

# Auth private key (RSA 2048, generated automatically)
# AUTH_PRIVATE_KEY=

# Viktor Spaces project secret (required for hosted deployment)
# VIKTOR_SPACES_PROJECT_SECRET=

# ─── Live Data Providers (R11) ───
# Server-side only — NEVER prefix with VITE_ (keys must not reach the browser)
# Set these in your Convex dashboard under Settings → Environment Variables
THE_ODDS_API_KEY=
SPORTSDATA_IO_KEY=
KALSHI_API_KEY=

# ─── Admin Access (R11.2) ───
# Comma-separated list of emails allowed to trigger sync actions.
# If empty, any authenticated user can call admin wrappers (dev mode).
# ADMIN_EMAILS=nick@example.com,dev@propedge.ai
