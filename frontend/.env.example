# ─── Supabase ───────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Backend API ─────────────────────────────────────────────
# URL of your deployed backend (default: localhost:3001)
VITE_API_URL=http://localhost:3001

# ══════════════════════════════════════════════════════════════
# ⚠️  SERVER-SIDE ONLY — NEVER prefix with VITE_
# These keys must NOT reach the browser!
# Set these on the backend as .env or Railway environment variables
# ══════════════════════════════════════════════════════════════

# Supabase (backend only — service role for admin operations)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# The Odds API (https://the-odds-api.com)
# THE_ODDS_API_KEY=

# API-SPORTS (https://api-sports.io)
# API_SPORTS_KEY=

# TheSportsDB (https://www.thesportsdb.com)
# THESPORTSDB_API_KEY=

# Ball Don't Lie (https://www.balldontlie.io) — NBA stats
# BALLDONTLIE_API_KEY=

# Kalshi prediction market (https://trading-api.kalshi.com)
# KALSHI_API_KEY=

# SerpApi for web search (https://serpapi.com)
# SERPAPI_KEY=

# OpenAI API for AI Analyst Chat (https://platform.openai.com)
# OPENAI_API_KEY=

# ─── Admin & Testing ─────────────────────────────────────────
# Comma-separated list of emails allowed to trigger admin actions.
# Example: ADMIN_EMAILS=nick@example.com,dev@propedge.ai
ADMIN_EMAILS=

# Token for smoke test CLI (see scripts/)
SMOKE_TEST_TOKEN=
