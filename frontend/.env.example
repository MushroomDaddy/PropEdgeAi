# ─── Convex Deployment ───────────────────────────────────────────
# VITE_CONVEX_URL goes in local frontend env (.env.local)
# Get this from: npx convex deploy or Convex Dashboard → Settings → Deployment
VITE_CONVEX_URL=

# Convex deploy key (optional, for CI/CD)
# CONVEX_DEPLOY_KEY=

# Auth private key (RSA 2048, generated automatically by Convex Auth)
# AUTH_PRIVATE_KEY=

# ─── Live Data Providers ──────────────────────────────────────────
# ⚠️  SERVER-SIDE ONLY — NEVER prefix with VITE_
# These keys must NOT reach the browser!
# Set these in: Convex Dashboard → Settings → Environment Variables
# DO NOT put them in .env.local (frontend can see them!)

# The Odds API (https://the-odds-api.com)
THE_ODDS_API_KEY=

# API-SPORTS (https://api-sports.io) — used by convex/apiSportsSync.ts
API_SPORTS_KEY=

# SportsData.io (alternative provider)
SPORTSDATA_IO_KEY=

# TheSportsDB (https://www.thesportsdb.com) — free dev key: 123
# Default/free dev key is set to 123 in the code
THESPORTSDB_API_KEY=123

# Ball Don't Lie (https://www.balldontlie.io) — NBA stats
BALLDONTLIE_API_KEY=

# Kalshi prediction market (https://trading-api.kalshi.com)
KALSHI_API_KEY=

# SerpApi for web search (https://serpapi.com)
SERPAPI_KEY=

# OpenAI API for AI Analyst Chat (https://platform.openai.com)
OPENAI_API_KEY=

# ─── Admin & Testing ─────────────────────────────────────────────
# Comma-separated list of emails allowed to trigger admin sync actions.
# If empty, any authenticated user can call admin wrappers (dev mode only).
# Example: ADMIN_EMAILS=nick@example.com,dev@propedge.ai
ADMIN_EMAILS=

# Token for goLiveSmokeTest (Step 5).
# Set this in Convex Dashboard, not in local .env files.
# Used to gate the smoke test endpoint for security.
SMOKE_TEST_TOKEN=

# ─── Viktor Spaces (optional) ────────────────────────────────────
# VIKTOR_SPACES_PROJECT_SECRET=
