# ─── Database ─────────────────────────────────────────────────
# Postgres connection string (Supabase)
# From: Supabase Dashboard → Project Settings → Database
DATABASE_URL=

# ─── Supabase Auth ─────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Data Providers ────────────────────────────────────────────
# The Odds API (https://the-odds-api.com)
THE_ODDS_API_KEY=

# Ball Don't Lie — NBA player stats (https://www.balldontlie.io)
BALLDONTLIE_API_KEY=

# ─── Internal ──────────────────────────────────────────────────
INTERNAL_API_KEY=
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Admin ─────────────────────────────────────────────────────
# Comma-separated emails for admin access
ADMIN_EMAILS=
